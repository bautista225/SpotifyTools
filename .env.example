# Spotify Developer Client ID (from https://developer.spotify.com/dashboard)
VITE_CLIENT_ID=YOUR-SPOTIFY-DEVELOPER-CLIENT-ID

# Redirect URI used during local development. It MUST be registered exactly the
# same in the Spotify app dashboard under "Redirect URIs".
# NOTE: Spotify rejects http://localhost ("Insecure Request URL"); use the
# explicit loopback address 127.0.0.1 instead (the only http:// URI allowed).
VITE_AUTHENTICATION_REDIRECT_URI=http://127.0.0.1:5173/authToken
